<komply>
  <rules>
    <max-line-length value="140" tier="maintainability" weight="2" />
    <max-lines value="2500" tier="maintainability" weight="5" />
    <forbid-trailing-whitespace tier="style" weight="2" />
    <require-final-newline tier="style" weight="1" />

    <forbid-regex pattern="\b(TODO|FIXME)\b" tier="delivery" weight="4" include-strings="false" />
    <forbid-regex pattern="\b(var_dump|print_r|die|exit)\s*\(" tier="debug-artifacts" weight="7" />
  </rules>
</komply>
